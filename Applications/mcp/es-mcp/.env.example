# .env.example — Elasticsearch MCP Server configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to source control — it contains credentials.
# ---------------------------------------------------------------

# ----- Connection -----------------------------------------------

# Full URL of your Elasticsearch instance, including scheme and port.
# Optional — defaults to https://localhost:9200 if not set.
ELASTIC_URL=https://localhost:9200

# ----- Authentication -------------------------------------------

# Basic-auth username for Elasticsearch.
# Optional — defaults to "elastic" if not set.
ELASTIC_USER=elastic

# Basic-auth password for Elasticsearch.
# REQUIRED in production — no default is safe to use.
ELASTIC_PASSWORD=your_password_here

# ----- TLS / Certificate ----------------------------------------

# Absolute path to the CA certificate used to verify Elasticsearch's
# TLS certificate.  Required when using a self-signed certificate
# (the default for locally installed Elasticsearch).
# Example value points to the default Elasticsearch install location.
ELASTIC_CA_CERTS=/path/to/elasticsearch/config/certs/http_ca.crt
